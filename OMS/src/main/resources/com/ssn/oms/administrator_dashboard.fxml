<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ssn.oms.controllers.AdministratorDashboardController">
    <children>
        <!-- Header Label for the Dashboard -->
        <Label layoutX="50.0" layoutY="21.0" styleClass="header-label" text="Administrator Dashboard" />

        <!-- Main VBox containing dashboard buttons and quick actions, centered on the screen -->
        <VBox alignment="TOP_CENTER" layoutX="50.0" layoutY="91.0" prefHeight="136.0" prefWidth="353.0" spacing="30">

            <!-- Dashboard Action Buttons -->
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="manageEmp" onAction="#handleManageEmployees" prefHeight="30.0" prefWidth="125.0" styleClass="button" text="Manage Employees" />
                <Button fx:id="manageDept" onAction="#handleManageDepartments" prefHeight="30.0" prefWidth="125.0" styleClass="button" text="Manage Departments" />
            </HBox>

            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="viewReports" onAction="#handleViewReports" prefHeight="30.0" prefWidth="125.0" styleClass="button" text="View Reports" />
                <Button fx:id="settings" onAction="#handleSettings" prefHeight="30.0" prefWidth="125.0" styleClass="button" text="Settings" />
            </HBox>

            <!-- Log Out Button with separate styling for visibility -->
            <Button fx:id="logoutButton" maxWidth="100.0" onAction="#handleLogout" prefHeight="30.0" styleClass="button logout-button" text="Log Out" />
        </VBox>

        <!-- Quick Actions VBox for additional functionalities -->
        <VBox alignment="CENTER" layoutX="390.0" layoutY="17.0" prefHeight="284.0" prefWidth="196.0" spacing="15.0">
            <Label styleClass="sub-header" text="Quick Actions" />
            <Button fx:id="addEmployee" onAction="#handleAddEmployee" prefHeight="30.0" prefWidth="125.0" styleClass="quick-button" text="Add Employee" />
            <Button fx:id="removeEmployee" onAction="#handleRemoveEmployee" prefHeight="30.0" prefWidth="125.0" styleClass="quick-button" text="Remove Employee" />
            <Button fx:id="generateReport" onAction="#handleGenerateReport" prefHeight="30.0" prefWidth="125.0" styleClass="quick-button" text="Generate Report" />
            <padding>
                <Insets top="50.0" />
            </padding>
        </VBox>
        <TextField fx:id="txtTemp" layoutX="21.0" layoutY="274.0" visible="false" />
    </children>
</AnchorPane>
